ASHARE_HMM_DB_PATH=data/db/a_share_hmm.duckdb
ASHARE_HMM_CACHE_DIR=data/cache
ASHARE_HMM_LOG_LEVEL=INFO
ASHARE_HMM_MARKET_DATA_SOURCE=tushare
ASHARE_HMM_TUSHARE_TOKEN=<your-tushare-token>
ASHARE_HMM_TUSHARE_POINTS=2000
ASHARE_HMM_TUSHARE_RATE_LIMIT_PER_MINUTE=200
ASHARE_HMM_TUSHARE_REQUEST_MIN_INTERVAL_SECONDS=0.31
ASHARE_HMM_TUSHARE_REQUEST_JITTER_SECONDS=0.02
ASHARE_HMM_TUSHARE_DAILY_INCLUDE_BASIC=true
ASHARE_HMM_TUSHARE_QFQ_ADJUSTMENT_ENABLED=true
ASHARE_HMM_TUSHARE_SW_LEVEL=L2
ASHARE_HMM_TUSHARE_SW_SOURCE=SW2021
